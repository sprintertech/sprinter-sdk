        "openapi": "api-reference/miso/openapi.json",
        "groups": [
          {
            "group": "User & Registration",
            "pages": [
              "GET /health",
              "POST /miso/username/check",
              "POST /miso/referral/validate",
              "POST /miso/register",
              "GET /miso/user"
            ]
          },
          {
            "group": "Cards",
            "pages": [
              "GET /miso/cards",
              "POST /miso/cards",
              "PATCH /miso/cards/{cardId}",
              "DELETE /miso/cards/{cardId}"
            ]
          }
        ]
      },
      {
        "tab": "Sprinter API",
        "openapi": "api-reference/sprinter/openapi.json",
        "groups": [
          {
            "group": "Solver",
            "pages": [
              "GET /protocol/{protocol}/solver"
            ]
          },
          {
            "group": "Credit",
            "pages": [
              "GET /credit/protocol",
              "GET /credit/accounts/{account}/info",
              "GET /credit/accounts/{account}/lock",
              "GET /credit/accounts/{account}/unlock",
              "GET /credit/accounts/{account}/draw",
              "GET /credit/accounts/{account}/repay",
              "GET /credit/collateral/{chain}/{collateral}",
              "GET /credit/earn/wrap",
              "GET /credit/earn/unwrap"
            ]
          },
          {
            "group": "Liquidity",
            "pages": [
              "GET /liquidity/pools/{poolType}",
              "POST /liquidity/v1/chain/{chain}/protocol/{protocol}/unlock"
            ]
          }
        ]
      },
      {
        "tab": "Signing API",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/signing/introduction"]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/signing/submit-signing",
              "api-reference/signing/get-signing-status",
              "api-reference/signing/request-unlock",
              "api-reference/signing/get-confirmations"
            ]
          }
        ]
      },
      {
        "tab": "Architecture",
        "groups": [
          {
            "group": "System Design",
            "pages": ["architecture/stash-repayment"]
          }
        ]
      }
