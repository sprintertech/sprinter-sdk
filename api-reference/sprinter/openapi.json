          "totalCollateral": {
            "description": "TotalCollateral is the total amount of deposited collateral in token units displayed in highest denomination.",
            "type": "string",
            "example": "1000.00"
          },
          "totalCollateralValue": {
            "description": "TotalCollateralValue is amount of usable collateral in token units displayed in highest denomination.",
            "type": "string",
            "example": "1500.50"
          }
        }
