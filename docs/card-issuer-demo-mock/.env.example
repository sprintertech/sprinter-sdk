# Required — wallet with USDC + ETH on Base
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional — Base RPC (defaults to public endpoint)
RPC_URL=https://mainnet.base.org

# Optional — amount of USDC for the demo (default: 1.00)
DEMO_AMOUNT=1.00

# Optional — dry run mode (API calls real, no on-chain txs)
DRY_RUN=true

# Port for the web UI
PORT=3003
